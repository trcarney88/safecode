{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "Engineer",
  "permission": {
    "read": {
      "~/Documents/*": "allow"
    },
    "write": {
      "~/Documents/*": "allow"
    },
    "edit": {
      "~/Documents/*": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "Bearer ${CONTEXT7_API_KEY}"
      },
      "enabled": true,
      "oauth": false
    }
  }
}
